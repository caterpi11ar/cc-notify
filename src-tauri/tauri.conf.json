{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Notify",
  "version": "0.2.0",
  "identifier": "com.ccnotify.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1111",
    "beforeDevCommand": "pnpm run build:cli && pnpm run dev:renderer",
    "beforeBuildCommand": "pnpm run build:all"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CC Notify",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 560,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "deb"],
    "resources": ["resources/cc-notify*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
