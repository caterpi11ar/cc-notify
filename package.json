    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "cross-fetch": "^4.1.0",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
